# Copy to .env and fill in. All paths are relative to project root by default.

# OpenAI-compatible API (DashScope, DeepSeek, SiliconFlow, OpenAI, etc.)
OPENAI_API_KEY=
# Optional: custom base URL, e.g. https://api.openai.com/v1
OPENAI_BASE_URL=

# Model names (OpenAI-style ID or provider-specific)
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# RAG
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_K=5
RERANK_TOP_N=0
USE_HYBRID=false
USE_MMR=true
MMR_LAMBDA=0.5

# Storage (relative to cwd)
DATA_DIR=./data
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_PATH=./data/finrag.db
FILE_STORAGE_DIR=./data/storage

# API security (if empty, auth middleware is off — dev only)
API_KEY=
JWT_SECRET=change-me-in-production
SESSION_TTL_MINUTES=120

# Fine-tuning paths (for training scripts)
TRAIN_DATA_PATH=./training/data/train.jsonl
LORA_OUTPUT_DIR=./data/lora_out

# Dev: mock LLM for automated tests (no real API)
DEV_MOCK_LLM=false
